// Template for assert/<service>.go.
//
// Replace placeholders:
//   {{Service}}     — TitleCase service name, e.g. KMS
//   {{servicepkg}}  — SDK service package short name, e.g. kms
//   {{servicelower}} — lowercase service name, e.g. kms
//
// File goes at assert/{{servicelower}}.go.
//
// Then add to assert/assert.go (in alphabetical order with the existing vars):
//
//   // {{Service}} provides {{Service}} assertion methods.
//   var {{Service}} {{servicelower}}Asserts
//
// Pattern: every assertion method has a paired *Context variant. The
// shim form (no ctx) forwards to the *Context variant with tb.Context().
// Cleanup paths (when applicable) use context.WithoutCancel(ctx).

package assert

import (
	"context"
	"testing"

	"github.com/aws/aws-sdk-go-v2/aws"
	"github.com/aws/aws-sdk-go-v2/service/{{servicepkg}}"

	// "github.com/donaldgifford/libtftest"  // uncomment if Pro-only
	"github.com/donaldgifford/libtftest/awsx"
)

type {{servicelower}}Asserts struct{}

// ResourceExistsContext is the ctx-aware variant of ResourceExists.
func ({{servicelower}}Asserts) ResourceExistsContext(tb testing.TB, ctx context.Context, cfg aws.Config, name string) {
	tb.Helper()
	// libtftest.RequirePro(tb)  // uncomment if Pro-only

	client := awsx.New{{Service}}(cfg)
	_, err := client.<DescribeOrGet>(ctx, &{{servicepkg}}.<Input>{
		<Field>: aws.String(name),
	})
	if err != nil {
		tb.Errorf("ResourceExists(%q): %v", name, err)
	}
}

// ResourceExists is a shim that calls ResourceExistsContext with tb.Context().
func (s {{servicelower}}Asserts) ResourceExists(tb testing.TB, cfg aws.Config, name string) {
	tb.Helper()
	s.ResourceExistsContext(tb, tb.Context(), cfg, name)
}

// ResourceHasPropertyContext is the ctx-aware variant of ResourceHasProperty.
func ({{servicelower}}Asserts) ResourceHasPropertyContext(tb testing.TB, ctx context.Context, cfg aws.Config, name, want string) {
	tb.Helper()
	// libtftest.RequirePro(tb)  // uncomment if Pro-only

	client := awsx.New{{Service}}(cfg)
	out, err := client.<DescribeOrGet>(ctx, &{{servicepkg}}.<Input>{
		<Field>: aws.String(name),
	})
	if err != nil {
		tb.Errorf("ResourceHasProperty(%q, %q): %v", name, want, err)
		return
	}

	got := string(out.<Field>)
	if got != want {
		tb.Errorf("ResourceHasProperty(%q): got %q, want %q", name, got, want)
	}
}

// ResourceHasProperty is a shim that calls ResourceHasPropertyContext with tb.Context().
func (s {{servicelower}}Asserts) ResourceHasProperty(tb testing.TB, cfg aws.Config, name, want string) {
	tb.Helper()
	s.ResourceHasPropertyContext(tb, tb.Context(), cfg, name, want)
}

