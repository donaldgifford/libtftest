// Template for assert/{{servicelower}}/{{servicelower}}.go.
//
// Replace placeholders:
//   {{Service}}      — TitleCase service name, e.g. KMS
//   {{servicepkg}}   — SDK service package short name, e.g. kms
//   {{servicelower}} — lowercase service name (= package name), e.g. kms
//
// Per the IMPL-0004 / DESIGN-0003 layout, each AWS service gets its
// own assert/<service>/ sub-package with package-level functions —
// NOT methods on a zero-size struct. The function names drop the
// service prefix (the package name carries it):
//
//   s3assert.BucketExists    (not assert.S3.BucketExists)
//   ddbassert.TableExists    (not assert.DynamoDB.TableExists)
//
// Don't forget the companion doc.go (one file per package). See
// any existing assert/<service>/doc.go for the format.
//
// Pattern: every assertion has a paired *Context variant. The shim
// form (no ctx) forwards to the *Context variant with tb.Context().
// Cleanup paths (when applicable) use context.WithoutCancel(ctx).
//
// Pro-only assertions call libtftest.RequirePro(tb) AND carry a
// `// libtftest:requires pro <reason>` marker comment per INV-0004.

package {{servicelower}}

import (
	"context"
	"testing"

	"github.com/aws/aws-sdk-go-v2/aws"
	{{servicepkg}}sdk "github.com/aws/aws-sdk-go-v2/service/{{servicepkg}}"

	// "github.com/donaldgifford/libtftest"  // uncomment if Pro-only
	"github.com/donaldgifford/libtftest/awsx"
)

// ResourceExistsContext asserts that the named {{Service}} resource exists.
//
// libtftest:requires pro <reason>  // uncomment if Pro-only
func ResourceExistsContext(tb testing.TB, ctx context.Context, cfg aws.Config, name string) {
	tb.Helper()
	// libtftest.RequirePro(tb)  // uncomment if Pro-only

	client := awsx.New{{Service}}(cfg)
	_, err := client.<DescribeOrGet>(ctx, &{{servicepkg}}sdk.<Input>{
		<Field>: aws.String(name),
	})
	if err != nil {
		tb.Errorf("ResourceExists(%q): %v", name, err)
	}
}

// ResourceExists is a shim that calls ResourceExistsContext with tb.Context().
//
// libtftest:requires pro <reason>  // uncomment if Pro-only
func ResourceExists(tb testing.TB, cfg aws.Config, name string) {
	tb.Helper()
	ResourceExistsContext(tb, tb.Context(), cfg, name)
}

// ResourceHasPropertyContext asserts that the named {{Service}} resource has the given property value.
//
// libtftest:requires pro <reason>  // uncomment if Pro-only
func ResourceHasPropertyContext(tb testing.TB, ctx context.Context, cfg aws.Config, name, want string) {
	tb.Helper()
	// libtftest.RequirePro(tb)  // uncomment if Pro-only

	client := awsx.New{{Service}}(cfg)
	out, err := client.<DescribeOrGet>(ctx, &{{servicepkg}}sdk.<Input>{
		<Field>: aws.String(name),
	})
	if err != nil {
		tb.Errorf("ResourceHasProperty(%q, %q): %v", name, want, err)
		return
	}

	got := string(out.<Field>)
	if got != want {
		tb.Errorf("ResourceHasProperty(%q): got %q, want %q", name, got, want)
	}
}

// ResourceHasProperty is a shim that calls ResourceHasPropertyContext with tb.Context().
//
// libtftest:requires pro <reason>  // uncomment if Pro-only
func ResourceHasProperty(tb testing.TB, cfg aws.Config, name, want string) {
	tb.Helper()
	ResourceHasPropertyContext(tb, tb.Context(), cfg, name, want)
}

