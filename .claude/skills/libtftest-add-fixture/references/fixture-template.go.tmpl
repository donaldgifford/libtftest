// Template for fixtures/{{servicelower}}/{{servicelower}}.go.
//
// Replace placeholders:
//   {{Service}}      — TitleCase service name, e.g. DynamoDB
//   {{servicepkg}}   — SDK service package short name, e.g. dynamodb
//   {{servicelower}} — lowercase service name (= package name), e.g. dynamodb
//   {{Verb}}         — Put, Create, Add, Send, etc.
//   {{Resource}}     — TitleCase resource name (drops service prefix), e.g.
//                      Item (not DynamoDBItem), Stream (not KinesisStream)
//   {{params...}}    — additional typed parameters specific to this seed
//   {{<DeleteVerb>}} — matching cleanup verb (Delete, Destroy, Remove)
//
// Per the IMPL-0004 / DESIGN-0003 layout, each AWS service gets its
// own fixtures/<service>/ sub-package with package-level functions.
// Function names drop the service prefix (the package name carries it):
//
//   s3fix.SeedObject       (not fixtures.SeedS3Object)
//   ssmfix.SeedParameter   (not fixtures.SeedSSMParameter)
//   sqsfix.SeedMessage     (not fixtures.SeedSQSMessage)
//
// Don't forget the companion doc.go (one file per package). See
// any existing fixtures/<service>/doc.go for the format.
//
// Pattern: every Seed function has a paired Seed*Context variant. The
// shim form (no ctx) forwards to the *Context variant with tb.Context().
// Cleanup callbacks use context.WithoutCancel(ctx) so they survive
// test-end cancellation.

package {{servicelower}}

import (
	"context"
	"testing"

	"github.com/aws/aws-sdk-go-v2/aws"
	{{servicepkg}}sdk "github.com/aws/aws-sdk-go-v2/service/{{servicepkg}}"

	"github.com/donaldgifford/libtftest/awsx"
)

// Seed{{Resource}}Context {{verb-phrase, e.g. "creates a DynamoDB item"}}
// and registers cleanup (via context.WithoutCancel) to {{cleanup-phrase}}.
func Seed{{Resource}}Context(tb testing.TB, ctx context.Context, cfg aws.Config, {{params...}}) {
	tb.Helper()

	client := awsx.New{{Service}}(cfg)

	_, err := client.{{Verb}}{{Resource}}(ctx, &{{servicepkg}}sdk.{{Verb}}{{Resource}}Input{
		// fields based on params
	})
	if err != nil {
		tb.Fatalf("Seed{{Resource}}({{format-args}}): %v", {{args}}, err)
	}

	cleanupCtx := context.WithoutCancel(ctx)
	tb.Cleanup(func() {
		_, err := client.{{<DeleteVerb>}}{{Resource}}(cleanupCtx, &{{servicepkg}}sdk.{{<DeleteVerb>}}{{Resource}}Input{
			// matching identifier fields
		})
		if err != nil {
			tb.Errorf("cleanup Seed{{Resource}}({{format-args}}): %v", {{args}}, err)
		}
	})
}

// Seed{{Resource}} is a shim that calls Seed{{Resource}}Context with tb.Context().
func Seed{{Resource}}(tb testing.TB, cfg aws.Config, {{params...}}) {
	tb.Helper()
	Seed{{Resource}}Context(tb, tb.Context(), cfg, {{args}})
}

