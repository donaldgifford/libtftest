// Template for a Seed* function in fixtures/fixtures.go.
//
// Replace placeholders:
//   {{Service}}       — TitleCase service name, e.g. DynamoDB
//   {{servicepkg}}    — SDK package short name, e.g. dynamodb
//   {{Verb}}          — Put, Create, Add, Send, etc.
//   {{Resource}}      — TitleCase resource name, e.g. Item, Stream, Topic
//   {{params...}}     — additional typed parameters specific to this seed
//   {{<DeleteVerb>}}  — matching cleanup verb (Delete, Destroy, Remove)
//
// Pattern: every Seed function has a paired Seed*Context variant. The
// shim form (no ctx) forwards to the *Context variant with tb.Context().
// Cleanup callbacks use context.WithoutCancel(ctx) so they survive
// test-end cancellation.
//
// Add both functions to fixtures/fixtures.go in alphabetical order by
// service. Add the SDK import to the existing import block (alphabetical).

import "github.com/aws/aws-sdk-go-v2/service/{{servicepkg}}"

// Seed{{Service}}{{Resource}}Context {{verb-phrase, e.g. "creates a DynamoDB item"}}
// and registers cleanup (via context.WithoutCancel) to {{cleanup-phrase}}.
func Seed{{Service}}{{Resource}}Context(tb testing.TB, ctx context.Context, cfg aws.Config, {{params...}}) {
	tb.Helper()

	client := awsx.New{{Service}}(cfg)

	_, err := client.{{Verb}}{{Resource}}(ctx, &{{servicepkg}}.{{Verb}}{{Resource}}Input{
		// fields based on params
	})
	if err != nil {
		tb.Fatalf("Seed{{Service}}{{Resource}}({{format-args}}): %v", {{args}}, err)
	}

	cleanupCtx := context.WithoutCancel(ctx)
	tb.Cleanup(func() {
		_, err := client.{{<DeleteVerb>}}{{Resource}}(cleanupCtx, &{{servicepkg}}.{{<DeleteVerb>}}{{Resource}}Input{
			// matching identifier fields
		})
		if err != nil {
			tb.Errorf("cleanup Seed{{Service}}{{Resource}}({{format-args}}): %v", {{args}}, err)
		}
	})
}

// Seed{{Service}}{{Resource}} is a shim that calls Seed{{Service}}{{Resource}}Context with tb.Context().
func Seed{{Service}}{{Resource}}(tb testing.TB, cfg aws.Config, {{params...}}) {
	tb.Helper()
	Seed{{Service}}{{Resource}}Context(tb, tb.Context(), cfg, {{args}})
}

