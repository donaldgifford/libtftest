// Seed{{Service}}{{Resource}} {{verb-phrase, e.g. "creates a DynamoDB item"}}
// and registers cleanup to {{cleanup-phrase, e.g. "delete it"}}.
func Seed{{Service}}{{Resource}}(tb testing.TB, cfg aws.Config, {{params...}}) {
	tb.Helper()

	client := awsx.New{{Service}}(cfg)
	ctx := context.Background()

	_, err := client.{{Verb}}{{Resource}}(ctx, &{{servicepkg}}.{{Verb}}{{Resource}}Input{
		// fields based on params
	})
	if err != nil {
		tb.Fatalf("Seed{{Service}}{{Resource}}({{format-args}}): %v", {{args}}, err)
	}

	tb.Cleanup(func() {
		_, err := client.{{<DeleteVerb>}}{{Resource}}(ctx, &{{servicepkg}}.{{<DeleteVerb>}}{{Resource}}Input{
			// matching identifier fields
		})
		if err != nil {
			tb.Errorf("cleanup Seed{{Service}}{{Resource}}({{format-args}}): %v", {{args}}, err)
		}
	})
}

