# syntax=docker/dockerfile:1

FROM golang:1.26-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /sneakystack ./cmd/sneakystack

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /sneakystack /sneakystack

EXPOSE 4567

ENTRYPOINT ["/sneakystack"]
